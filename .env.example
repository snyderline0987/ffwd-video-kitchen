# Video Kitchen Box — Configuration
# Copy this to .env and fill in your keys

# === Required: At least one AI provider ===
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# === Optional: Chat Integration ===
# Connect the agent to your team chat
DISCORD_TOKEN=
TELEGRAM_BOT_TOKEN=

# === Optional: Remote Access ===
# Tailscale for secure remote access to the dashboard
TS_AUTHKEY=

# === Optional: Raw Footage Mount ===
# Path on host machine where raw video files live
# Leave empty to use ./raw_footage (create it first)
RAW_FOOTAGE_PATH=
